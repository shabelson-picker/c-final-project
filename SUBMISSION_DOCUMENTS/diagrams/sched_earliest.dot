digraph sched_earliest {
  rankdir=TB;
  graph [fontname="Helvetica", label="Scheduling Strategy 1/3: Earliest-Deadline (nominal)", labelloc=t, fontsize=15];
  node [shape=box, fontname="Helvetica", fontsize=10, style="filled,rounded", fillcolor="#fff4e6"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  ex   [shape=record, fillcolor="#f7f9fc",
        label="{shared example task|min=2  likely=4  max=12  risk=0.5|pert_expected = (2 + 4*4 + 12) / 6 = 5}"];
  F    [label="effective_duration(t, s) = pert_expected", fillcolor="#ffe9cc"];
  calc [label="= 5 days", fillcolor="#d8f5d8"];
  use  [shape=note, fillcolor="#fffbe6",
        label="Use: the plain plan. Schedule on the\nmost-likely estimate, ignore risk.\nShortest of the three -> tightest makespan."];
  cmp  [shape=note, fillcolor="#eef4ff", label="vs risk-weighted 6 d, pessimistic 12 d"];

  ex -> F -> calc;
  F -> use [style=dashed, arrowhead=none];
  calc -> cmp [style=dashed, arrowhead=none];
}
