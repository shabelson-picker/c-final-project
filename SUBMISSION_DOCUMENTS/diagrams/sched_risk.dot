digraph sched_risk {
  rankdir=TB;
  graph [fontname="Helvetica", label="Scheduling Strategy 2/3: Risk-Weighted Critical Path", labelloc=t, fontsize=15];
  node [shape=box, fontname="Helvetica", fontsize=10, style="filled,rounded", fillcolor="#fff4e6"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  ex   [shape=record, fillcolor="#f7f9fc",
        label="{shared example task|min=2  likely=4  max=12  risk=0.5|pert_expected = (2 + 4*4 + 12) / 6 = 5}"];
  F    [label="effective_duration(t, s) =\npert_expected * (1 + risk * 0.5)", fillcolor="#ffe9cc"];
  calc [label="= 5 * (1 + 0.5 * 0.5) = 5 * 1.25 = 6.25\n-> 6 days", fillcolor="#d8f5d8"];
  use  [shape=note, fillcolor="#fffbe6",
        label="Use: hedge. Risky tasks are stretched\nin proportion to their risk, so they are\nmore likely to land on the critical path\nand get protected slack."];
  cmp  [shape=note, fillcolor="#eef4ff", label="vs earliest-deadline 5 d, pessimistic 12 d"];

  ex -> F -> calc;
  F -> use [style=dashed, arrowhead=none];
  calc -> cmp [style=dashed, arrowhead=none];
}
