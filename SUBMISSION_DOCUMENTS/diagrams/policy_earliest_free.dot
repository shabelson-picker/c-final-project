digraph policy_earliest_free {
  rankdir=TB;
  graph [fontname="Helvetica", label="Assignment Policy 1/3: Earliest-Free (default, tight makespan)", labelloc=t, fontsize=15];
  node [shape=box, fontname="Helvetica", fontsize=10, style="filled,rounded", fillcolor="#eef4ff"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  cand [shape=record, fillcolor="#f7f9fc",
        label="{shared candidates - all qualified for a BACKEND task|Spec   surplus=0  free_day=8  load=2|Free   surplus=2  free_day=1  load=5|Light  surplus=1  free_day=4  load=0}"];
  key  [label="score_key (lexicographic, lower wins):\n[ free_day, load, surplus, id ]\nsurplus = popcount(skills & ~required)", fillcolor="#cfe0ff"];
  pick [label="primary = free_day -> min is Free (1)\nPICK: Free", fillcolor="#d8f5d8"];
  note [shape=note, fillcolor="#fffbe6",
        label="Use: get work started as soon as possible.\nPacks tasks onto whoever frees up first ->\nshortest overall schedule (default)."];

  cand -> key -> pick -> note;
}
