digraph sched_pessimistic {
  rankdir=TB;
  graph [fontname="Helvetica", label="Scheduling Strategy 3/3: Pessimistic (worst-case)", labelloc=t, fontsize=15];
  node [shape=box, fontname="Helvetica", fontsize=10, style="filled,rounded", fillcolor="#fff4e6"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  ex   [shape=record, fillcolor="#f7f9fc",
        label="{shared example task|min=2  likely=4  max=12  risk=0.5|(pert_expected = 5, unused here)}"];
  F    [label="effective_duration(t, s) = pert_max", fillcolor="#ffe9cc"];
  calc [label="= 12 days", fillcolor="#d8f5d8"];
  use  [shape=note, fillcolor="#fffbe6",
        label="Use: worst case. Plan every task at its\npessimistic estimate - the safest, longest\nschedule. Good for commit-by dates."];
  cmp  [shape=note, fillcolor="#eef4ff", label="vs earliest-deadline 5 d, risk-weighted 6 d"];

  ex -> F -> calc;
  F -> use [style=dashed, arrowhead=none];
  calc -> cmp [style=dashed, arrowhead=none];
}
